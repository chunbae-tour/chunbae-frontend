# EC2 백엔드 연동용 환경변수 예시입니다.
# 로컬에서 배포 백엔드와 붙여 테스트하려면 이 파일을 .env.ec2로 복사해서 사용합니다.
# 실행 명령: corepack pnpm dev:ec2
# 빌드 명령: corepack pnpm build:ec2

# 배포된 백엔드 API의 루트 주소입니다.
# 프론트 공통 API 클라이언트가 /api/v1을 자동으로 붙입니다.
# 따라서 아래 값에는 /api/v1을 절대 붙이지 않습니다.
# 실제 API 호출 예:
# VITE_API_BASE_URL=https://api.chunbae-tour.site
# fetch 대상=https://api.chunbae-tour.site/api/v1/...
VITE_API_BASE_URL=https://api.chunbae-tour.site

# true면 API 실패를 mock 데이터로 숨기지 않고 화면에 에러로 보여줍니다.
# 배포/EC2 연동 테스트에서는 true를 유지합니다.
VITE_STRICT_API=true

# 채팅 WebSocket/SockJS 설정입니다.
# 이 값을 생략하면 프론트가 자동으로 VITE_API_BASE_URL + /ws-stomp를 사용합니다.
# 현재 기본 연결 주소는 https://api.chunbae-tour.site/ws-stomp 입니다.
# 백엔드 WebSocket 경로가 달라질 때만 아래 주석을 풀고 직접 지정합니다.
# VITE_STOMP_SOCKJS_URL=https://api.chunbae-tour.site/ws-stomp
VITE_STOMP_SEND_PREFIX=/pub
VITE_STOMP_SUBSCRIBE_PREFIX=/sub

# 카카오 지도 JavaScript SDK 키입니다.
# VITE_로 시작하는 값은 브라우저 JS에 포함되므로 비밀키를 넣으면 안 됩니다.
# 카카오 개발자 콘솔에 아래 프론트 도메인을 JavaScript 키 허용 도메인으로 등록해야 합니다.
# - https://chunbae-tour.site
# - https://www.chunbae-tour.site
VITE_KAKAO_MAP_APP_KEY=
