# 로컬 개발용 환경변수 예시입니다.
# 팀원은 이 파일을 .env로 복사한 뒤 자기 환경에 맞게 값을 바꿔서 사용합니다.
# .env 파일은 git에 올라가지 않습니다.

# 백엔드 서버의 루트 주소만 적습니다.
# 프론트 공통 API 클라이언트가 /api/v1을 자동으로 붙입니다.
# 올바른 예: http://localhost:8080
# 잘못된 예: http://localhost:8080/api/v1
VITE_API_BASE_URL=http://localhost:8080

# true면 API 실패를 mock 데이터로 숨기지 않고 화면에 에러로 보여줍니다.
# 백엔드 연동 테스트 단계에서는 true를 권장합니다.
# 화면 UI만 빠르게 확인할 때는 false로 둘 수 있습니다.
VITE_STRICT_API=false

# 카카오 지도 JavaScript SDK 키입니다.
# 백엔드에서 쓰는 REST API 키와 다릅니다.
# 카카오 개발자 콘솔에 http://localhost:5173 을 JavaScript 키 허용 도메인으로 등록해야 합니다.
# 배포 후에는 https://chunbae-tour.site 도 추가로 등록해야 합니다.
VITE_KAKAO_MAP_APP_KEY=

# 휴대폰 실기기 테스트 참고:
# 1. 카카오 JS SDK 허용 도메인에 https://<PC IPv4>:5173 을 등록합니다.
#    위치 권한은 보통 http://IP 주소에서 막히므로 https가 필요합니다.
# 2. 실행: corepack pnpm dev:mobile
# 3. 휴대폰에서 https://<PC IPv4>:5173 접속
# 4. 자체 서명 인증서 경고를 통과한 뒤 지도 화면에서 위치 권한을 허용합니다.
