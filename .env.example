# Backend base URL only. Do not include /api/v1 here.
VITE_API_BASE_URL=http://localhost:8080

# false: keep mock fallback when an API is missing or fails.
# true: show real API errors and block mock fallback for integration testing.
VITE_STRICT_API=false

# Kakao Map JavaScript SDK key (not the REST API key used on the backend).
# Register http://localhost:5173 and your production domain in the Kakao Developers console.
VITE_KAKAO_MAP_APP_KEY=

# Mobile device test (geolocation + Kakao Map on phone):
# 1. Register https://<PC IPv4>:5173 in Kakao JS SDK domains (http://IP will not get location permission).
# 2. Run: pnpm dev:mobile
# 3. Open https://<PC IPv4>:5173 on the phone and accept the self-signed certificate warning.
# 4. Tap "위치 사용 허용" on the map screen.
